{
  "id": "mars-channel",
  "name": "Mars",
  "description": "Mars channel plugin for OpenClaw (Bot Gateway relay).",
  "version": "1.0.0",
  "author": "",
  "license": "MIT",
  "main": "dist/plugin.js",
  "engines": {
    "openclaw": ">=1.0.0"
  },
  "channels": ["mars"],
  "openclaw": {
    "extensions": ["./src/plugin.ts"],
    "setupEntry": "./src/setup-entry.ts",
    "channel": {
      "id": "mars",
      "label": "Mars",
      "selectionLabel": "Mars (Bot Gateway)",
      "docsPath": "/channels/mars",
      "docsLabel": "Mars Docs",
      "blurb": "Mars channel: connect your web chat to local OpenClaw via Bot Gateway.",
      "order": 99,
      "aliases": ["mars"]
    },
    "install": {
      "npmSpec": "openclaw-channel-custom",
      "localPath": "extensions/custom-channel",
      "defaultChoice": "npm"
    },
    "startup": {
      "deferConfiguredChannelFullLoadUntilAfterListen": false
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "transport": {
        "type": "string",
        "enum": ["webhook", "websocket", "polling"],
        "default": "webhook"
      },
      "webhook": {
        "type": "object",
        "properties": {
          "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 3100 },
          "path": { "type": "string", "default": "/webhook/custom" }
        }
      },
      "websocketUrl": {
        "type": "string",
        "format": "uri"
      },
      "pollingIntervalMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 3000
      },
      "dmPolicy": {
        "type": "string",
        "enum": ["open", "pairing", "allowlist"],
        "default": "pairing"
      },
      "allowFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "groupPolicy": {
        "type": "string",
        "enum": ["open", "allowlist", "disabled"],
        "default": "disabled"
      },
      "groupAllowFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "groups": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "disabled": { "type": "boolean" },
            "allowFrom": { "type": "array", "items": { "type": "string" } },
            "requireMention": { "type": "boolean" }
          }
        }
      },
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "required": ["apiBaseUrl", "apiToken"],
          "properties": {
            "label": { "type": "string" },
            "apiBaseUrl": { "type": "string", "format": "uri" },
            "apiToken": { "type": "string", "minLength": 1 },
            "webhookSecret": { "type": "string" }
          }
        },
        "minProperties": 1
      },
      "network": {
        "type": "object",
        "properties": {
          "proxyUrl": { "type": "string", "format": "uri" }
        }
      }
    },
    "required": ["accounts"],
    "additionalProperties": false
  },
  "uiHints": {
    "accounts.*.apiBaseUrl": {
      "label": "API Base URL",
      "placeholder": "https://api.your-product.com"
    },
    "accounts.*.apiToken": {
      "label": "API Token",
      "placeholder": "sk-...",
      "sensitive": true
    },
    "accounts.*.webhookSecret": {
      "label": "Webhook Secret",
      "placeholder": "whsec-...",
      "sensitive": true
    },
    "transport": {
      "label": "Transport Mode",
      "placeholder": "webhook"
    },
    "webhook.port": {
      "label": "Webhook Port",
      "placeholder": "3100"
    },
    "webhook.path": {
      "label": "Webhook Path",
      "placeholder": "/webhook/custom"
    },
    "websocketUrl": {
      "label": "WebSocket URL",
      "placeholder": "wss://ws.your-product.com/events"
    }
  }
}
